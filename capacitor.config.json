{
  "appId": "com.forgewar.rts",
  "appName": "ForgeWar",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#0d1117",
    "overrideUserAgent": null,
    "appendUserAgent": "ForgeWar/1.0"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor":    "#0d1117",
      "showSpinner":        false
    },
    "Keyboard": {
      "resize": "none"
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0d1117"
    }
  }
}
